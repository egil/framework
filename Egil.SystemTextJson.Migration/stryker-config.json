{
  "stryker-config": {
    "project": "src/Egil.SystemTextJson.Migration/Egil.SystemTextJson.Migration.csproj",
    "test-projects": [
      "test/Egil.SystemTextJson.Migration.Tests/Egil.SystemTextJson.Migration.Tests.csproj"
    ],
    "reporters": [
      "json",
      "progress",
      "cleartext"
